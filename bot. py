import os
import re
import sys
import math
import json
import subprocess
import tempfile
import traceback
from telegram import Update
from telegram.ext import Application, CommandHandler, MessageHandler, filters, ContextTypes
from groq import Groq

TELEGRAM_TOKEN = os.environ["TELEGRAM_TOKEN"]
GROQ_API_KEY = os.environ["GROQ_API_KEY"]

client = Groq(api_key=GROQ_API_KEY)
MODEL = "llama-3.3-70b-versatile"

TOOLS = [
    {
        "type": "function",
        "function": {
            "name": "run_python",
            "description": "Execute Python code and return the output. Always use print() for output.",
            "parameters": {
                "type": "object",
                "properties": {
                    "code": {"type": "string", "description": "Valid Python 3 code."}
                },
                "required": ["code"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "calculate",
            "description": "Evaluate a safe math expression. Supports +,-,*,/,**,%,sqrt,sin,cos,log.",
            "parameters": {
                "type": "object",
                "properties": {
                    "expression": {"type": "string", "description": "Math expression"}
                },
                "required": ["expression"],
            },
        },
    },
]

SYSTEM_PROMPT = """You are a helpful AI assistant inside Telegram with two tools:
1. run_python – Execute Python 3 code
2. calculate – Evaluate math expressions

Rules:
- For ANY math or coding question, always use one of the tools.
- Respond in the same language as the user (Persian, Tajik, Russian, English).
- Be concise and clear.
"""

def run_python(code: str) -> str:
    try:
        with tempfile.NamedTemporaryFile(mode="w", suffix=".py", delete=False) as f:
            f.write(code)
            fname = f.name
        result = subprocess.run([sys.executable, fname], capture_output=True, text=True, timeout=15)
        os.unlink(fname)
        output = result.stdout.strip()
        error = result.stderr.strip()
        if error and not output:
            return f"❌ Error:\n{error}"
        return output if output else "(no output)"
    except subprocess.TimeoutExpired:
        return "❌ Timeout: 15 seconds exceeded."
    except Exception as e:
        return f"❌ Error: {e}"

def calculate(expression: str) -> str:
    safe_names = {k: getattr(math, k) for k in dir(math) if not k.startswith("_")}
    safe_names.update({"abs": abs, "round": round, "pow": pow})
    try:
        clean = re.sub(r"[^0-9+\-*/().,%\s_a-zA-Z]", "", expression)
        return str(eval(clean, {"__builtins__": {}}, safe_names))
    except Exception as e:
        return f"❌ Error: {e}"

def dispatch_tool(name: str, args: dict) -> str:
    if name == "run_python":
        return run_python(args["code"])
    if name == "calculate":
        return calculate(args["expression"])
    return f"Unknown tool: {name}"

def agent_loop(user_message: str, history: list) -> str:
    messages = [{"role": "system", "content": SYSTEM_PROMPT}]
    messages += history
    messages.append({"role": "user", "content": user_message})
    for _ in range(8):
        response = client.chat.completions.create(
            model=MODEL, messages=messages, tools=TOOLS, tool_choice="auto", max_tokens=2048
        )
        msg = response.choices[0].message
        if response.choices[0].finish_reason == "stop" or not msg.tool_calls:
            return msg.content or "✅ Done."
        messages.append({
            "role": "assistant", "content": msg.content or "",
            "tool_calls": [{"id": tc.id, "type": "function", "function": {"name": tc.function.name, "arguments": tc.function.arguments}} for tc in msg.tool_calls]
        })
        for tc in msg.tool_calls:
            try:
                args = json.loads(tc.function.arguments)
            except Exception:
                args = {}
            messages.append({"role": "tool", "tool_call_id": tc.id, "content": dispatch_tool(tc.function.name, args)})
    return "⚠️ Max iterations reached."

chat_histories: dict[int, list] = {}
MAX_HISTORY = 10

def get_history(chat_id): return chat_histories.get(chat_id, [])
def update_history(chat_id, user_msg, assistant_msg):
    h = chat_histories.setdefault(chat_id, [])
    h += [{"role": "user", "content": user_msg}, {"role": "assistant", "content": assistant_msg}]
    if len(h) > MAX_HISTORY * 2:
        chat_histories[chat_id] = h[-(MAX_HISTORY * 2):]

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("👋 سلام! من دستیار هوش مصنوعی هستم.\n\n🔢 محاسبات ریاضی\n🐍 اجرای کد Python\n\nهر سوالی داری بپرس!")

async def clear_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    chat_histories.pop(update.effective_chat.id, None)
    await update.message.reply_text("🗑️ تاریخچه پاک شد.")

async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    chat_id = update.effective_chat.id
    user_text = update.message.text.strip()
    await context.bot.send_chat_action(chat_id=chat_id, action="typing")
    try:
        reply = agent_loop(user_text, get_history(chat_id))
        update_history(chat_id, user_text, reply)
    except Exception:
        reply = f"❌ خطا:\n{traceback.format_exc()[-300:]}"
    if len(reply) > 4000:
        reply = reply[:3990] + "\n…(ادامه دارد)"
    await update.message.reply_text(reply)

def main():
    app = Application.builder().token(TELEGRAM_TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("clear", clear_cmd))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))
    print("🤖 Bot is running...")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()
